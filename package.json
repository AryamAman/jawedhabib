{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "npm run db:generate && next build --webpack",
    "vercel-build": "node scripts/vercel-build.mjs",
    "preview": "next start",
    "start": "next start",
    "clean": "rm -rf .next dist",
    "lint": "tsc --noEmit",
    "db:generate": "node scripts/run-prisma.mjs generate",
    "db:migrate:deploy": "node scripts/run-prisma.mjs migrate deploy",
    "db:seed": "node --experimental-strip-types seed.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.2.2",
